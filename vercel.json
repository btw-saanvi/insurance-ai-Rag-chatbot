{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/recommend",
      "destination": "/api/index.py"
    },
    {
      "source": "/chat",
      "destination": "/api/index.py"
    },
    {
      "source": "/upload-policy",
      "destination": "/api/index.py"
    },
    {
      "source": "/admin/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/docs",
      "destination": "/api/index.py"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/index.py"
    }
  ]
}

